{
  "opencode_version": "1.17.18",
  "provider_package": "@ai-sdk/openai-compatible",
  "endpoint": "/v1/chat/completions",
  "initial_request": {
    "model": "mock",
    "max_tokens": 4096,
    "messages": [
      {
        "role": "system",
        "content": "Use tools to complete the requested coding task."
      },
      {
        "role": "user",
        "content": "Read target.txt."
      }
    ],
    "tools": [
      {
        "type": "function",
        "function": {
          "name": "read",
          "description": "Read a file from the local workspace.",
          "parameters": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "type": "object",
            "properties": {
              "filePath": {
                "type": "string"
              }
            },
            "required": [
              "filePath"
            ]
          }
        }
      }
    ],
    "tool_choice": "auto",
    "stream": true,
    "stream_options": {
      "include_usage": true
    }
  },
  "request_after_tool": {
    "model": "mock",
    "max_tokens": 4096,
    "messages": [
      {
        "role": "system",
        "content": "Use tools to complete the requested coding task."
      },
      {
        "role": "user",
        "content": "Read target.txt."
      },
      {
        "role": "assistant",
        "content": "",
        "tool_calls": [
          {
            "id": "call_capture",
            "type": "function",
            "function": {
              "name": "read",
              "arguments": "{\"filePath\":\"target.txt\"}"
            }
          }
        ]
      },
      {
        "role": "tool",
        "tool_call_id": "call_capture",
        "content": "TOKEN=before\n"
      }
    ],
    "tools": [
      {
        "type": "function",
        "function": {
          "name": "read",
          "description": "Read a file from the local workspace.",
          "parameters": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "type": "object",
            "properties": {
              "filePath": {
                "type": "string"
              }
            },
            "required": [
              "filePath"
            ]
          }
        }
      }
    ],
    "tool_choice": "auto",
    "stream": true,
    "stream_options": {
      "include_usage": true
    }
  }
}
