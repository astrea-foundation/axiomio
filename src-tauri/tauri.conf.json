{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AxiomIO",
  "version": "0.1.2",
  "identifier": "systems.astrea.axiomio",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5273",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AxiomIO",
        "width": 360,
        "height": 520,
        "minWidth": 360,
        "minHeight": 520,
        "maxWidth": 360,
        "maxHeight": 520,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "fullscreen": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/tray.png",
      "iconAsTemplate": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libayatana-appindicator3-1"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {}
}
